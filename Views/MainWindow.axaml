<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FNF_Manager.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="FNF_Manager.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="FNF Manager">

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid
        Background="{DynamicResource BackgroundColor}">
        <Border
          BorderBrush="{DynamicResource SidebarSeparator}"
          BorderThickness="0,0,2,0"
          Padding="10"
          Width="180"
          HorizontalAlignment="Left">
            <Grid>
            <StackPanel>
                <TextBlock
                           VerticalAlignment="Center"
                           Margin="0,0,0,5"
                           FontWeight="Bold"
                           FontSize="20"
                           LetterSpacing="0.25"
                           Text="{StaticResource AppName}"/>
                <Border
                    Height="1"
                    Background="{DynamicResource SidebarSeparator}"
                    HorizontalAlignment="Stretch"
                    Margin="0,0,-10,10"/>
                <Button
                    Margin="0,0,0,5"
                    FontSize="20"
                    Classes="sidebar-button"
                    Content="Base game" />
                <Button
                    Margin="0,0,0,5"
                    FontSize="20"
                    Classes="sidebar-button"
                    Content="Mods" />
            </StackPanel>
            <StackPanel
                VerticalAlignment="Bottom">
                <Border
                    Height="1"
                    Background="{DynamicResource SidebarSeparator}"
                    HorizontalAlignment="Stretch"
                    Margin="0,0,-10,10"/>
                <Button
                    HorizontalAlignment="Stretch"
                    Margin="0,0,0,5"
                    FontSize="20"
                    Classes="sidebar-button"
                    Content="Settings" />
            </StackPanel>
            </Grid>
            <Border.Background>
                <RadialGradientBrush
                    Center="50%,50%"
                    GradientOrigin="50%,50%">
                    <GradientStop Offset="0.0" Color="{DynamicResource LeftGraidentInner}" />
                    <GradientStop Offset="1.0" Color="{DynamicResource LeftGraidentOuter}" />
                </RadialGradientBrush>
            </Border.Background>
        </Border>

        <ContentControl Grid.Column="1"
                    Content="{Binding CurrentPage}"/>

        <Border HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="{DynamicResource WelcomeTextBack}"
            CornerRadius="12"
            Padding="24,12"
            Opacity="1">
            <Border.Styles>
                <Style Selector="Border">
                    <Style.Animations>
                        <Animation Duration="0:0:1.5"
                                   FillMode="Forward">
                            <KeyFrame Cue="0%">
                                <Setter Property="Opacity" Value="1"/>
                            </KeyFrame>

                            <KeyFrame Cue="65%">
                                <Setter Property="Opacity" Value="1"/>
                            </KeyFrame>

                            <KeyFrame Cue="100%">
                                <Setter Property="Opacity" Value="0"/>
                            </KeyFrame>
                        </Animation>
                    </Style.Animations>
                </Style>
            </Border.Styles>

            <StackPanel>
                <TextBlock Foreground="{DynamicResource WelcomeTextFore}"
                   FontSize="28"
                   FontWeight="Bold">
                    <Run 
                        Text="Welcome to " /><Run
                        Text="{StaticResource AppName}" /><Run
                        Text="!" />
                </TextBlock>
                <TextBlock
                    Foreground="{DynamicResource WelcomeTextFore}"
                    FontSize="14"
                    HorizontalAlignment="Center"
                    Margin="0,5,0,0"
                    Text="Created by JohnB"/>
            </StackPanel>
        </Border>
    </Grid>

    <Window.Styles>
        <Style Selector="Button.sidebar-button">
            <Setter Property="Background" Value="{DynamicResource SidebarButtonBG}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextColor}"/>
            <Setter Property="BorderBrush" Value="Black"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style Selector="Button.sidebar-button:pointerover">
            <Setter Property="Background" Value="{DynamicResource SidebarButtonBGHover}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextColor}"/>
            <Setter Property="BorderBrush" Value="Black"/>
        </Style>

        <Style Selector="Button.sidebar-button:pressed">
            <Setter Property="Background" Value="{DynamicResource SidebarButtonBGPressed}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextColor}"/>
            <Setter Property="BorderBrush" Value="Black"/>
        </Style>
    </Window.Styles>
</Window>
